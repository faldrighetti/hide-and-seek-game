rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function gameDoc(gameId) {
      return get(/databases/$(database)/documents/games/$(gameId));
    }

    function isMember(gameId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/games/$(gameId)/seats/$(request.auth.uid));
    }

    function isHost(gameId) {
      return isMember(gameId)
        && gameDoc(gameId).data.hostUid == request.auth.uid;
    }

    match /games/{gameId} {
      allow read: if isMember(gameId);
      allow create, update, delete: if false;

      match /seats/{seatUid} {
        allow read: if isMember(gameId);
        allow create, update, delete: if false;
      }

      match /questions/{questionId} {
        allow read: if isMember(gameId);
        allow create, update, delete: if false;
      }

      match /{sub=**}/{docId} {
        allow read: if isMember(gameId);
        allow write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}